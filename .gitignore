# =============================================================================
# RAG ANEEL — .gitignore
# =============================================================================

# ── Dados gerados pelo pipeline (gerar localmente rodando setup_pipeline.py)
# JSONs gerados por limpar_json_aneel.py
data/aneel_limpo_completo.json
data/aneel_vigentes_completo.json
# Qualquer outro JSON gerado na raiz de data/ (não confundir com data/raw/)
data/*.json

# Todos os parquets e checkpoints gerados por parser.py / chunker_json.py
data/processed/

# Logs de runtime gerados pela API
data/logs/

# ── Arquivos binários gerados (grandes e regeneráveis)
# Índices BM25 (db/bm25/bm25_index.pkl, bm25_ids.pkl)
*.pkl
# Parquets de qualquer localização
*.parquet
# Índices binários (ex: bge_index.bin gerado no Colab)
*.bin

# ── Banco de dados local (gerado por p2_indexar.py)
db/

# ── PDFs e arquivos baixados da ANEEL (~27k arquivos)
# Baixar rodando: python scripts/setup_pipeline.py
pdfs/

# ── Falhas e logs do download
falhas_download.json
falhas_playwright.json
pdfs/downloads_referenciados.json

# ── Scripts de debug e versões antigas na raiz (movidos para scripts/)
debug_json.py
setup_pipeline.py

# ── Dependências externas (instalar manualmente — ver SETUP.md)
# Poppler para Windows (OCR) — instalar dentro do projeto
poppler/

# ── Ambiente virtual Python
venv/
.venv/
env/
.env/

# ── Cache Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so

# ── Build e distribuição
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Variáveis de ambiente — NUNCA versionar chaves de API
.env
.env.local
.env.*.local
.env.production

# ── IDEs e editores
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sublime-project
*.sublime-workspace

# ── Sistema operacional
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs e arquivos temporários
*.log
*.tmp
*.bak
*.swp

# ── Jupyter
.ipynb_checkpoints/
*.ipynb

# ── Testes e cobertura
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Claude settings locais
.claude/
