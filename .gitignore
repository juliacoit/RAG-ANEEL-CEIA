# =============================================================================
# RAG ANEEL — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Dados — nunca versionar PDFs nem Parquets processados
# ---------------------------------------------------------------------------
data/raw/*.pdf
data/raw/*.html
data/processed/
data/samples/*.parquet

# ---------------------------------------------------------------------------
# Variáveis de ambiente — nunca commitar chaves de API
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Ambientes virtuais
venv/
.venv/
env/
.env/

# Distribuição / build
build/
dist/
*.egg-info/
*.egg

# ---------------------------------------------------------------------------
# Testes e cobertura
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ---------------------------------------------------------------------------
# IDEs e editores
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs e temporários
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
