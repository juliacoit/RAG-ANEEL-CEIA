# =============================================================================
# RAG ANEEL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com os seus valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# APIs de IA
OPENAI_API_KEY=sk-...
GROQ_API_KEY=sk-ant-...

# Qdrant (Vector Store)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Configurações da Pipeline
CHUNK_SIZE=600
CHUNK_OVERLAP=90
TOP_K_RETRIEVAL=5
LLM_MODEL=llama-3.3-70b-versatile
