# Copie este arquivo para .env e preencha com suas chaves reais
# cp env.example .env   (Linux/macOS)
# copy env.example .env (Windows)

# ── LLM Principal — Qwen3-30B-A3B via Dashscope ───────────────────────────────
# Obter em: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── LLM Fallback 1 — Groq (gratuito, 100k tokens/dia) ────────────────────────
# Ativado automaticamente quando Qwen falha
# Obter em: https://console.groq.com/ (sem cartão de crédito)
GROQ_API_KEY=gsk_...

# ── LLM Fallback 2 — Gemini Flash (opcional) ─────────────────────────────────
# Ativado quando Groq também falha — deixe vazio para desabilitar
# Obter em: https://aistudio.google.com/
GEMINI_API_KEY=

# ── Configuração dos modelos ───────────────────────────────────────────────────
LLM_PROVIDER=qwen                                    # qwen | groq | gemini
LLM_MODEL=qwen3-30b-a3b                              # modelo Qwen principal
GROQ_MODEL=llama-3.3-70b-versatile                   # modelo Groq fallback
GEMINI_MODEL=gemini-2.0-flash                        # modelo Gemini fallback

# ── Cadeia de fallback automático ─────────────────────────────────────────────
# Qwen3-30B → Groq Llama-3.3-70B → Gemini Flash → mensagem de erro clara

# ── Qdrant local (Docker) ─────────────────────────────────────────────────────
# Não precisa alterar se estiver rodando localmente
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_chunks

# ── Configurações de busca ────────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
OPTIMIZER_TIMEOUT=12
