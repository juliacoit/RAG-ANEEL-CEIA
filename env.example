# =============================================================================
# RAG ANEEL — Configuração de Ambiente (EXEMPLO)
# =============================================================================
# Copie este arquivo para .env e preencha com suas chaves reais:
#   Windows : copy env.example .env
#   Linux   : cp env.example .env
#
# ⚠️  NUNCA commite o arquivo .env — ele contém segredos.
# =============================================================================

# ── Vector Store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_chunks

# ── LLM Primário: Qwen via DashScope (OpenAI-compatible) ──────────────────────
# Obtenha em: https://dashscope.console.aliyun.com/apiKey
LLM_PROVIDER=qwen
LLM_MODEL=qwen3-30b-a3b
QWEN_API_KEY=sk-...
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ── LLM Fallback: Groq — gratuito (console.groq.com) ─────────────────────────
# Obtenha sua chave em: https://console.groq.com (sem cartão de crédito)
GROQ_API_KEY=gsk_...
LLM_FALLBACK_MODEL=llama-3.3-70b-versatile

# ── OpenAI — embeddings para RAGAS ResponseRelevancy (opcional) ───────────────
# Usado apenas para avaliação RAGAS. Sem chave usa embeddings locais.
OPENAI_API_KEY=

# ── Recuperação ───────────────────────────────────────────────────────────────
TOP_K_RETRIEVAL=5
OPTIMIZER_TIMEOUT=12

# ── Avaliação (eval_runner.py) ────────────────────────────────────────────────
# Pasta de saída dos CSVs de avaliação (relativa à raiz do projeto)
EVAL_OUTPUT_DIR=docs
# Caminho para o banco de perguntas (relativo à raiz)
EVAL_QUESTIONS_PATH=src/evaluation/banco_perguntas.py
