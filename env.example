# =============================================================================
# RAG ANEEL — Configuração de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com suas chaves reais:
#   Windows : copy env.example .env
#   Linux   : cp env.example .env
#
# ⚠️  NUNCA commite o arquivo .env — ele contém segredos.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM — Provedor e Modelos
# -----------------------------------------------------------------------------

# Provedor principal. Opções: qwen | groq | gemini
LLM_PROVIDER=qwen

# Modelo primário (Qwen via Dashscope — API OpenAI-compatible)
LLM_MODEL=qwen3-30b-a3b

# Chave da API Qwen — obtenha em: https://dashscope.console.aliyun.com/apiKey
QWEN_API_KEY=sk-...

# URL base da API Qwen:
#   Internacional (fora da China) : https://dashscope-intl.aliyuncs.com/compatible-mode/v1
#   China mainland                 : https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1


# -----------------------------------------------------------------------------
# LLM — Fallback 1: Groq (gratuito)
# -----------------------------------------------------------------------------
# Ativado automaticamente se o Qwen falhar ou retornar erro.
# Obtenha sua chave em: https://console.groq.com  (sem cartão de crédito)
# Limite gratuito: ~100k tokens/dia

GROQ_API_KEY=gsk_...

# Modelo do Groq usado como fallback
GROQ_MODEL=llama-3.3-70b-versatile


# -----------------------------------------------------------------------------
# LLM — Fallback 2: Gemini (opcional)
# -----------------------------------------------------------------------------
# Ativado se Groq também falhar. Deixe em branco se não quiser usar.
# Obtenha sua chave em: https://aistudio.google.com  (gratuito)

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash


# -----------------------------------------------------------------------------
# Qdrant — Banco Vetorial
# -----------------------------------------------------------------------------

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_chunks


# -----------------------------------------------------------------------------
# Retrieval — Configurações de Busca
# -----------------------------------------------------------------------------

# Número de chunks recuperados por pergunta (padrão: 10)
TOP_K_RETRIEVAL=10

# Timeout do optimizer de query em segundos (padrão: 12)
OPTIMIZER_TIMEOUT=12


# -----------------------------------------------------------------------------
# (Opcional) OpenAI — Embeddings para avaliação RAGAS
# -----------------------------------------------------------------------------
# Necessário apenas para a métrica ResponseRelevancy no eval_ragas.py.
# Se não configurado, o sistema usa embeddings locais como fallback.

OPENAI_API_KEY=
