# Copie este arquivo para .env e preencha com suas chaves reais
# cp .env.example .env

# OpenAI — usada para embeddings (text-embedding-3-small) e geração (GPT-4o)
OPENAI_API_KEY=sk...

# Qdrant local (Docker) — não precisa alterar se estiver rodando localmente
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_chunks

# Anthropic — usada para geração com Claude (opcional, alternativa ao GPT-4o)
ANTHROPIC_API_KEY=sk-ant-...
