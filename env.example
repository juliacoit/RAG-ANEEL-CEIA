# Copie este arquivo para .env e preencha com suas chaves reais
# cp env.example .env

# ── LLM Principal ─────────────────────────────────────────────────────────────
# Groq — gratuito, sem cartão de crédito (100k tokens/dia)
# Obter em: https://console.groq.com/
GROQ_API_KEY=gsk_...

# ── LLM Fallback ──────────────────────────────────────────────────────────────
# DeepSeek R1 — usado automaticamente quando Groq retorna 429 (rate limit)
# Obter em: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# ── Configuração dos modelos ───────────────────────────────────────────────────
LLM_PROVIDER=groq                      # groq | deepseek
LLM_MODEL=llama-3.3-70b-versatile      # modelo Groq
DEEPSEEK_MODEL=deepseek-reasoner       # modelo DeepSeek R1

# ── Qdrant local (Docker) ─────────────────────────────────────────────────────
# Não precisa alterar se estiver rodando localmente
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=aneel_chunks

# ── Configurações de busca ────────────────────────────────────────────────────
TOP_K_RETRIEVAL=10
OPTIMIZER_TIMEOUT=12
